{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false,
    "outDir": "../electron-compiled",
    "rootDir": ".",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": false
  },
  "include": [
    "main.ts",
    "preload.ts",
    "tray.ts",
    "notifications.ts",
    "updater.ts"
  ]
}
