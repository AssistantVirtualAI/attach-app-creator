{
  "name": "ava-softphone",
  "version": "1.0.0",
  "description": "AVA Softphone — Professional Communication App",
  "main": "electron/main.js",
  "author": "AVA Télécom",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "build": "vite build && tsc -p electron/tsconfig.json && electron-builder",
    "build:win": "vite build && tsc -p electron/tsconfig.json && electron-builder --win",
    "build:mac": "vite build && tsc -p electron/tsconfig.json && electron-builder --mac",
    "build:linux": "vite build && tsc -p electron/tsconfig.json && electron-builder --linux",
    "dist": "npm run build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "jssip": "^3.10.0",
    "@supabase/supabase-js": "^2.39.0",
    "electron-updater": "^6.1.7",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "build": {
    "extends": "./build/electron-builder.yml"
  }
}
