{
  "name": "ava-softphone",
  "version": "1.0.0",
  "description": "AVA Softphone — Professional Communication App",
  "main": "electron/main.js",
  "author": "AVA Télécom",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "build": "vite build && tsc -p electron/tsconfig.json",
    "build:win": "npm run build && electron-builder --win --x64",
    "build:mac": "npm run build && electron-builder --mac --x64 --arm64",
    "build:linux": "npm run build && electron-builder --linux --x64",
    "dist": "npm run build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "jssip": "^3.10.0",
    "@supabase/supabase-js": "^2.39.0",
    "electron-updater": "^6.1.7",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@tailwindcss/forms": "^0.5.0",
    "autoprefixer": "10.4.21",
    "concurrently": "^9.1.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.21"
  },
  "build": {
    "extends": "./electron-builder.yml"
  }
}
