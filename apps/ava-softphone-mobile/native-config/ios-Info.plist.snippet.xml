<!--
  Merge these keys into ios/App/App/Info.plist after running `npx cap add ios`.
  Required for microphone, camera, push, and background audio for VoIP.
-->
<key>NSMicrophoneUsageDescription</key>
<string>Lemtel Telecom needs microphone access for phone calls</string>

<key>NSCameraUsageDescription</key>
<string>Lemtel Telecom needs camera access for video calls</string>

<key>NSContactsUsageDescription</key>
<string>Lemtel Telecom can use your contacts to place calls faster</string>

<key>UIBackgroundModes</key>
<array>
  <string>audio</string>
  <string>voip</string>
  <string>remote-notification</string>
</array>

<key>NSAppTransportSecurity</key>
<dict>
  <key>NSAllowsArbitraryLoads</key>
  <false/>
</dict>
