{
  "name": "lemtel-mobile",
  "version": "2.1.0",
  "description": "Lemtel Telecom — Mobile Softphone (iOS + Android)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:smoke": "vite build && vitest run src/test/build-smoke.test.ts",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "sync:ios": "npx cap sync ios",
    "sync:android": "npx cap sync android",
    "build:ios": "vite build && npx cap sync ios && npx cap open ios",
    "build:android": "vite build && npx cap sync android && npx cap open android"
  },
  "dependencies": {
    "@capacitor-community/contacts": "^6.0.1",
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/camera": "^6.1.0",
    "@capacitor/core": "^6.1.2",
    "@capacitor/device": "^6.0.1",
    "@capacitor/haptics": "^6.0.1",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/local-notifications": "^6.1.0",
    "@capacitor/network": "^6.0.2",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/push-notifications": "^6.0.2",
    "@capacitor/splash-screen": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1",
    "@supabase/supabase-js": "^2.76.1",
    "jssip": "^3.10.0",
    "lucide-react": "^1.21.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.5"
  }
}
